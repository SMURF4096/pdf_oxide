{
    "name": "oxide/pdf-oxide",
    "description": "PDF processing toolkit (Rust-backed, FFI-bound) for PHP",
    "type": "library",
    "license": ["MIT", "Apache-2.0"],
    "keywords": [
        "pdf",
        "text-extraction",
        "pdf-creation",
        "pdf-editing",
        "ocr",
        "signatures",
        "ffi",
        "rust"
    ],
    "authors": [
        {
            "name": "pdf_oxide contributors",
            "email": "releases@oxide.fyi"
        }
    ],
    "homepage": "https://github.com/yfedoseev/pdf_oxide",
    "support": {
        "issues": "https://github.com/yfedoseev/pdf_oxide/issues",
        "source": "https://github.com/yfedoseev/pdf_oxide"
    },
    "require": {
        "php": ">=8.2",
        "ext-ffi": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "PdfOxide\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PdfOxide\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": "@php scripts/download-native-lib.php",
        "post-update-cmd": "@php scripts/download-native-lib.php",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "test-coverage": "phpunit --coverage-html coverage",
        "lint": "@php -r 'foreach (new \\RecursiveIteratorIterator(new \\RecursiveDirectoryIterator(__DIR__.\"/src\")) as $f) if ($f->getExtension()===\"php\") { $r=0; passthru(\"php -l \" . escapeshellarg($f->getPathname()) . \" > /dev/null\", $r); if ($r) exit(1); }'",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "audit": "@composer audit --locked",
        "check": ["@cs-check", "@phpstan", "@test"]
    },
    "suggest": {
        "ext-gd": "Required for advanced image manipulation features",
        "ext-imagick": "Optional for enhanced rendering capabilities"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
